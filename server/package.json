{
  "name": "resume-fitter-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "cross-env RUN_INTEGRATION_TESTS=true vitest run --reporter=verbose tests/model.service.integration.test.ts",
    "test:eval": "cross-env TEST_EVAL=true vitest run --reporter=verbose tests/prompts",
    "test:eval:quality": "cross-env TEST_EVAL=true vitest run --reporter=verbose tests/prompts/rewrite-resume.integrity.eval.test.ts tests/eval/chatGuard.eval.test.ts",
    "test:eval:extract": "cross-env TEST_EVAL=true vitest run --reporter=verbose tests/prompts/job-extractor.eval.test.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.54",
    "@ai-sdk/google": "3.0.37",
    "@ai-sdk/openai": "3.0.39",
    "ai": "6.0.111",
    "dotenv": "17.3.1",
    "express": "5.2.1",
    "express-rate-limit": "8.2.1",
    "jsonwebtoken": "9.0.3",
    "multer": "^2.1.1",
    "ollama-ai-provider-v2": "3.3.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.3.3",
    "@types/supertest": "^7.2.0",
    "cross-env": "^10.1.0",
    "supertest": "^7.2.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
